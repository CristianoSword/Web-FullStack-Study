{
  "Worker": {
    "PollIntervalSeconds": 15,
    "RunOnStartup": true,
    "Jobs": [
      {
        "Name": "cleanup-temp-files",
        "Cron": "*/5 * * * *",
        "Handler": "cleanup",
        "Payload": "C:/temp/workspace"
      },
      {
        "Name": "sync-reports",
        "Cron": "*/10 * * * *",
        "Handler": "report-sync",
        "Payload": "finance-monthly"
      }
    ]
  }
}
