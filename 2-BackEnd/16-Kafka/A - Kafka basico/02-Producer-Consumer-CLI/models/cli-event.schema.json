  "type": "object",
  "required": ["eventId", "eventType", "source", "payload", "createdAt"],
  "properties": {
    "eventId": { "type": "string" },
    "eventType": { "type": "string" },
    "source": { "type": "string" },
    "payload": { "type": "object" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
