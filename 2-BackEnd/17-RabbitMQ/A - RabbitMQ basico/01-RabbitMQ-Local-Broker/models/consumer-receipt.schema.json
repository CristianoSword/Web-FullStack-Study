{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConsumerReceipt",
  "type": "object",
  "required": ["consumerTag", "ackedMessages", "lastMessageAt"],
  "properties": {
    "consumerTag": {
      "type": "string"
    },
    "ackedMessages": {
      "type": "integer",
      "minimum": 0
    },
    "lastMessageAt": {
      "type": ["string", "null"]
    }
  }
}
