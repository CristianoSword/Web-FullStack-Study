{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkerMetric",
  "type": "object",
  "required": ["workerId", "acked", "failed", "lastTaskAt", "status"],
  "properties": {
    "workerId": {
      "type": "string"
    },
    "acked": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "lastTaskAt": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["idle", "running"]
    }
  }
}
