{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoutedLog",
  "type": "object",
  "required": ["eventId", "severity", "message", "payload", "createdAt"],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "error", "audit"]
    },
    "message": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "createdAt": {
      "type": "string"
    }
  }
}
