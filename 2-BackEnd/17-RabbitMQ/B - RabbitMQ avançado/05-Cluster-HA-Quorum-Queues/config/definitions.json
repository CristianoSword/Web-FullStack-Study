{
  "vhosts": [{ "name": "/" }],
  "policies": [
    {
      "vhost": "/",
      "name": "ha-quorum-all",
      "pattern": "^cluster\\.",
      "apply-to": "queues",
      "definition": {
        "queue-type": "quorum",
        "delivery-limit": 5,
        "dead-letter-exchange": "cluster.dlx"
      },
      "priority": 50
    }
  ],
  "queues": [
    {
      "name": "cluster.orders.quorum",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "cluster.dlx"
      }
    },
    {
      "name": "cluster.orders.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "cluster.events",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "cluster.dlx",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "cluster.events",
      "vhost": "/",
      "destination": "cluster.orders.quorum",
      "destination_type": "queue",
      "routing_key": "cluster.order",
      "arguments": {}
    },
    {
      "source": "cluster.dlx",
      "vhost": "/",
      "destination": "cluster.orders.dlq",
      "destination_type": "queue",
      "routing_key": "cluster.order.dead",
      "arguments": {}
    }
  ]
}
