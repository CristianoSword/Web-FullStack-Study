{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["sku", "name", "category", "price", "stock", "warehouse"],
    "properties": {
      "sku": {
        "bsonType": "string",
        "description": "SKU unico do produto"
      },
      "name": {
        "bsonType": "string",
        "minLength": 3
      },
      "category": {
        "bsonType": "string"
      },
      "price": {
        "bsonType": ["double", "int", "long", "decimal"],
        "minimum": 0
      },
      "stock": {
        "bsonType": ["int", "long"],
        "minimum": 0
      },
      "warehouse": {
        "bsonType": "object",
        "required": ["code", "city"],
        "properties": {
          "code": {
            "bsonType": "string"
          },
          "city": {
            "bsonType": "string"
          }
        }
      },
      "tags": {
        "bsonType": "array",
        "items": {
          "bsonType": "string"
        }
      },
      "createdAt": {
        "bsonType": "date"
      }
    }
  }
}
