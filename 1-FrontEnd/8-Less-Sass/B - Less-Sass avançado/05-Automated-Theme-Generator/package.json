{
  "name": "05-automated-theme-generator",
  "version": "1.0.0",
  "description": "Gerador de temas dinamicos com mixins e funcoes Sass",
  "scripts": {
    "build:sass": "sass src/scss/main.scss src/css/style.css",
    "watch:sass": "sass --watch src/scss/main.scss:src/css/style.css"
  },
  "dependencies": {
    "sass": "^1.77.2"
  }
}
