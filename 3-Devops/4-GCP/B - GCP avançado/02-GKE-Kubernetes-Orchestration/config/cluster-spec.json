{
  "projectId": "study-platform-dev",
  "region": "us-central1",
  "clusterName": "study-gke-cluster",
  "releaseChannel": "REGULAR",
  "kubernetesVersion": "1.30",
  "network": "study-vpc",
  "subnetwork": "gke-services-us-central1",
  "privateCluster": true,
  "shieldedNodes": true,
  "workloadIdentityPool": "study-platform-dev.svc.id.goog",
  "loggingService": "logging.googleapis.com/kubernetes",
  "monitoringService": "monitoring.googleapis.com/kubernetes",
  "nodePools": [
    {
      "name": "system-pool",
      "machineType": "e2-standard-2",
      "minNodes": 1,
      "maxNodes": 3,
      "diskSizeGb": 100,
      "diskType": "pd-balanced",
      "preemptible": false,
      "labels": {
        "workload": "platform",
        "env": "study"
      }
    },
    {
      "name": "apps-pool",
      "machineType": "e2-standard-4",
      "minNodes": 2,
      "maxNodes": 6,
      "diskSizeGb": 100,
      "diskType": "pd-balanced",
      "preemptible": false,
      "labels": {
        "workload": "apps",
        "env": "study"
      }
    }
  ]
}
