{
  "schemaName": "order-event-v1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "order"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "order.created",
        "order.paid",
        "order.cancelled"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "order": {
      "type": "object",
      "required": [
        "id",
        "customerId",
        "amount",
        "currency"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "customerId": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        }
      }
    }
  }
}
