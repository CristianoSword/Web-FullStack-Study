{
  "deploymentName": "catalog-api",
  "namespace": "study-rolling",
  "replicas": 4,
  "strategy": {
    "type": "RollingUpdate",
    "maxSurge": 1,
    "maxUnavailable": 0
  },
  "revisionHistoryLimit": 5,
  "minReadySeconds": 10,
  "progressDeadlineSeconds": 180,
  "probes": {
    "startupPath": "/healthz",
    "livenessPath": "/healthz",
    "readinessPath": "/readyz"
  }
}
